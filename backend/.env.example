# Backend
PORT=5000
MONGODB_URI=mongodb://localhost:27017/campusway
MONGO_URI=mongodb://localhost:27017/campusway
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ACCESS_TOKEN_TTL_MINUTES=20
REFRESH_TOKEN_TTL_DAYS=7
ADMIN_SECRET_PATH=campusway-secure-admin
CORS_ORIGIN=http://localhost:5173,http://localhost:5175
FRONTEND_URL=http://localhost:5175
ADMIN_ORIGIN=http://localhost:5175
NODE_ENV=development
SENDGRID_API_KEY=
ADMIN_EMAIL=admin@campusway.example
ALLOW_DEFAULT_SETUP=true
ALLOW_TEST_OTP=true
TEST_OTP_CODE=123456
APP_DOMAIN=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@campusway.local

# Optional AWS storage
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=

# Optional Firebase admin integration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
